Bootstrap: docker
From: node:20-slim

%labels
    Author HapBrowser
    Version 4.0.0

%post
    # System dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip samtools ncbi-blast+ && \
    rm -rf /var/lib/apt/lists/*

    # Python dependencies
    pip3 install --break-system-packages pysam snakemake fastapi uvicorn pydantic

    # serve (static file server)
    npm install -g serve

    mkdir -p /app

%files
    package.json /app/package.json
    vite.config.js /app/vite.config.js
    index.html /app/index.html
    src /app/src
    backend /app/backend
    scripts /app/scripts
    Snakefile /app/Snakefile
    docker-entrypoint.sh /app/docker-entrypoint.sh

%post
    # Build frontend
    cd /app && npm install && npm run build
    chmod +x /app/docker-entrypoint.sh

%environment
    export PORT=8080
    export BLAST_PORT=8081
    export DATA_DIR=/data
    export LC_ALL=C.UTF-8

%runscript
    exec /app/docker-entrypoint.sh "$@"

%startscript
    exec /app/docker-entrypoint.sh serve

%help
    HapBrowser v4.0 — Rice Heading-Date Gene Haplotype Browser
    ============================================================

    Build (2 methods):

      Method 1 — Direct Singularity build (Linux only):
        cd hap-browser/
        sudo singularity build hap-browser.sif hap-browser.def

      Method 2 — Docker build → Singularity convert (macOS/Linux):
        docker build -t hap-browser .
        docker save hap-browser -o hap-browser.tar
        scp hap-browser.tar workstation:/path/
        # On workstation:
        singularity build hap-browser.sif docker-archive://hap-browser.tar

    Run:

      # Web server (data already exists)
      singularity run --bind /path/to/data:/data hap-browser.sif serve

      # Generate pileup data from BAMs
      singularity run --bind /path/to/data:/data hap-browser.sif pipeline

      # Specific gene only
      singularity run --bind /path/to/data:/data hap-browser.sif pipeline --gene Os06g0275000

      # Rebuild index.json
      singularity run --bind /path/to/data:/data hap-browser.sif index

      # Interactive shell
      singularity shell --bind /path/to/data:/data hap-browser.sif

    Data directory structure (/data):
      /data/
        index.json
        {group_name}/           # e.g., "Heading date genes"
          {gene_id}.fa
          {gene_id}.local.gff3
          {gene_id}.meta.json
        bam/{gene_id}/
          {sample}.bam (+.bai)
          samples.json
        pileup/{gene_id}/       # generated by pipeline
          {sample}.json
        blast_db/               # generated by server

    Ports:
      8080 - Frontend (change: --env PORT=3000)
      8081 - BLAST API (change: --env BLAST_PORT=3001)
